# Variables de Entorno — MapFI
# Copia este archivo a .env y completa los valores antes de arrancar.
# El archivo .env NUNCA debe subirse a GitHub (esta en .gitignore).
# En Railway/Render estas variables se configuran en el dashboard, no se usa .env.

# ── Servidor ────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development          # development | production

# ── Seguridad ───────────────────────────────────────────────────
# Secreto para firmar cookies de sesion.
# Genera uno con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=cambia-este-valor-por-uno-aleatorio-y-secreto

# ── Base de datos (OBLIGATORIA) ─────────────────────────────────
# DATABASE_URL es REQUERIDA: el server hace fail-fast si no esta seteada.
# Las migraciones corren automaticamente al arrancar.
#
# host vs contenedor:
#   - Este DATABASE_URL es para `npm start` / `npm run dev` en TU MAQUINA
#     (host) → apunta a localhost en el puerto PUBLICADO (${POSTGRES_PORT}).
#   - `docker compose up` IGNORA este DATABASE_URL y arma el suyo con el host
#     interno `db:5432` (ver docker-compose.yaml). Para docker solo necesitas
#     POSTGRES_USER/PASSWORD/DB/PORT de abajo.
DATABASE_URL=postgres://mapfi:local@localhost:5433/mapfi

# Credenciales del Postgres de docker-compose (servicio `db`).
POSTGRES_USER=mapfi
POSTGRES_PASSWORD=local
POSTGRES_DB=mapfi
POSTGRES_PORT=5433          # puerto publicado al host (interno siempre 5432)

# Tamano del pool de conexiones (default 10).
PG_POOL_MAX=10

# ── Cuenta de administrador inicial ─────────────────────────────
# Se crea automaticamente en la primera migracion (si aun no existe un admin).
# Puedes cambiar estos valores; si borras estas lineas se usan por defecto:
#   admin@mapfi.cl / admin1234   (CAMBIALA en produccion)
SEED_ADMIN_EMAIL=admin@mapfi.cl
SEED_ADMIN_PASSWORD=admin1234
