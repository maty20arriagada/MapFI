{
  "name": "mapfi",
  "version": "0.1.0",
  "description": "Plataforma de Mapeo, Planificacion y Co-diseno de Actividades de la Facultad de Ingenieria.",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "jest --forceExit",
    "test:watch": "jest --watch",
    "db:migrate": "node js/db/migrate.js",
    "docker:up": "docker compose up --build",
    "docker:down": "docker compose down",
    "docker:db": "docker compose up -d db"
  },
  "keywords": [
    "calendario",
    "facultad-ingenieria",
    "planificacion",
    "mapa-de-calor",
    "education"
  ],
  "author": "Matias Arriagada R.",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "jest": {
    "testEnvironment": "node",
    "setupFiles": [
      "<rootDir>/jest.setup.js"
    ],
    "testMatch": [
      "**/__tests__/**/*.test.js"
    ],
    "testPathIgnorePatterns": [
      "/node_modules/",
      "/.claude/"
    ],
    "coveragePathIgnorePatterns": [
      "/node_modules/"
    ],
    "testTimeout": 30000
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "connect-pg-simple": "^10.0.0",
    "express": "^4.18.2",
    "express-session": "^1.19.0",
    "pdfkit": "^0.15.2",
    "pg": "^8.20.0"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "nodemon": "^3.0.2",
    "pg-mem": "^3.0.14",
    "supertest": "^7.0.0"
  }
}
